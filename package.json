{
  "name": "skygest-cloudflare",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "effect-language-service patch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "dev": "bun --hot scripts/dev.ts",
    "build:web": "bun build src/web/app.tsx --outdir dist --target browser && bunx @tailwindcss/cli -i src/web/styles.css -o dist/styles.css && cp src/web/index.html dist/index.html",
    "build:web:prod": "bun build src/web/app.tsx --outdir dist --target browser --minify && bunx @tailwindcss/cli -i src/web/styles.css -o dist/styles.css --minify && cp src/web/index.html dist/index.html",
    "bootstrap:experts": "bun run src/scripts/bootstrap-experts.ts",
    "build:ontology-snapshot": "bun run src/scripts/build-ontology-snapshot.ts",
    "seed:ontology-kv": "bun run src/scripts/seed-ontology-kv.ts",
    "ops": "bun run src/scripts/ops.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260120.0",
    "@effect/language-service": "^0.71.2",
    "@effect/platform-bun": "4.0.0-beta.43",
    "@effect/sql-sqlite-bun": "4.0.0-beta.43",
    "@effect/sql-sqlite-node": "4.0.0-beta.43",
    "@effect/vitest": "4.0.0-beta.43",
    "@observablehq/plot": "^0.6.17",
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "d3": "^7.9.0",
    "jsdom": "^28.0.0",
    "ulid": "^3.0.2",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/sql-d1": "4.0.0-beta.43",
    "@google/genai": "^1.46.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "agents": "^0.0.104",
    "bun-plugin-tailwind": "^0.1.2",
    "effect": "4.0.0-beta.43",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
