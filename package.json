{
  "name": "skygest-cloudflare",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "prepare": "effect-language-service patch",
    "postinstall": "bun run scripts/fetch-ingest-artifacts.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:types": "bun run scripts/generate-worker-types.ts",
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p tsconfig.test.json && tsgo --noEmit -p tsconfig.web.json && tsgo --noEmit -p packages/ontology-store/tsconfig.json && tsgo --noEmit -p packages/ontology-store/tsconfig.test.json",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json",
    "dev": "bun --hot scripts/dev.ts",
    "build:web": "bun build src/web/app.tsx --outdir dist --target browser && bunx @tailwindcss/cli -i src/web/styles.css -o dist/styles.css && cp src/web/index.html dist/index.html",
    "build:web:prod": "bun build src/web/app.tsx --outdir dist --target browser --minify && bunx @tailwindcss/cli -i src/web/styles.css -o dist/styles.css --minify && cp src/web/index.html dist/index.html",
    "bootstrap:experts": "bun run src/scripts/bootstrap-experts.ts",
    "build:ontology-snapshot": "bun run src/scripts/build-ontology-snapshot.ts",
    "seed:ontology-kv": "bun run src/scripts/seed-ontology-kv.ts",
    "sync:data-layer": "bun run scripts/sync-data-layer.ts",
    "gen:data-layer-spine": "bun run scripts/generate-data-layer-spine.ts",
    "gen:emit-spec": "bun run scripts/generate-emit-spec.ts",
    "search-db:migrate": "bun run scripts/migrate-search-db.ts",
    "search-db:rebuild": "bun run scripts/rebuild-search-db.ts",
    "ops": "bun run src/scripts/ops.ts"
  },
  "devDependencies": {
    "@effect/language-service": "^0.71.2",
    "@effect/platform-bun": "4.0.0-beta.43",
    "@effect/sql-sqlite-bun": "4.0.0-beta.43",
    "@effect/sql-sqlite-node": "4.0.0-beta.43",
    "@effect/vitest": "4.0.0-beta.43",
    "@observablehq/plot": "^0.6.17",
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "d3": "^7.9.0",
    "fast-check": "^4.6.0",
    "jsdom": "^28.0.0",
    "ulid": "^3.0.2",
    "vitest": "^3.1.1",
    "wrangler": "^4.81.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/sql-d1": "4.0.0-beta.43",
    "@google/genai": "^1.46.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@typescript/native-preview": "^7.0.0-dev.20260411.1",
    "agents": "^0.0.104",
    "bun-plugin-tailwind": "^0.1.2",
    "effect": "4.0.0-beta.43",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.43"
  }
}
