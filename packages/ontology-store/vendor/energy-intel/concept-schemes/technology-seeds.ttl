@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ei-concept: <https://w3id.org/energy-intel/concept/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/energy-intel/modules/concept-schemes/technology-seeds> a owl:Ontology ;
    dcterms:created "2026-04-22"^^xsd:date ;
    dcterms:description "Minimal V0 technology SKOS tree (wind branch) for CQ-013/CQ-014 fixtures. Complements the BOT-extracted OEO plan-spec classes."@en ;
    dcterms:title "energy-intel — Technology SKOS seeds (V0)"@en ;
    owl:versionInfo "v0 (2026-04-22)" .

ei-concept:offshore-wind a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "offshore wind"@en ;
    skos:broader ei-concept:wind ;
    skos:definition "Wind technology installed on bodies of water."@en ;
    skos:inScheme ei-concept:technology ;
    skos:prefLabel "offshore wind"@en .

ei-concept:onshore-wind a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "onshore wind"@en ;
    skos:broader ei-concept:wind ;
    skos:definition "Wind technology installed on land."@en ;
    skos:inScheme ei-concept:technology ;
    skos:prefLabel "onshore wind"@en .

ei-concept:solar-pv a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "solar photovoltaic"@en ;
    skos:broader ei-concept:solar ;
    skos:definition "Solar PV cells generating electricity directly from sunlight."@en ;
    skos:inScheme ei-concept:technology ;
    skos:prefLabel "solar photovoltaic"@en .

ei-concept:solar a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "solar"@en ;
    skos:definition "Solar-based energy technology (top-level)."@en ;
    skos:inScheme ei-concept:technology ;
    skos:narrower ei-concept:solar-pv ;
    skos:prefLabel "solar"@en ;
    skos:topConceptOf ei-concept:technology .

ei-concept:wind a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "wind"@en ;
    skos:definition "Wind-based energy technology (top-level)."@en ;
    skos:inScheme ei-concept:technology ;
    skos:narrower ei-concept:offshore-wind,
        ei-concept:onshore-wind ;
    skos:prefLabel "wind"@en ;
    skos:topConceptOf ei-concept:technology .

ei-concept:technology a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "energy technology concepts"@en ;
    skos:definition "Local energy-technology SKOS scheme used as codomain of ei:aboutTechnology in V0."@en ;
    skos:hasTopConcept ei-concept:solar,
        ei-concept:wind ;
    skos:prefLabel "energy technology concepts"@en .
