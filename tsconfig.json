{
  "compilerOptions": {
    // Effect Language Service
    "plugins": [{ "name": "@effect/language-service" }],

    // Environment setup & latest features
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "bun"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Incremental typecheck cache (see SKY-298). `incremental: true` writes a
    // .tsbuildinfo next to the project; we redirect it under .cache/tsc/ so
    // the three configs (main / test / web) don't collide and CI can cache
    // the whole directory.
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsc/main.tsbuildinfo",

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "analysis/**",
    "src/**/*.test.ts",
    "src/filters/**",
    "src/services/CandidateSessionsRepo.ts",
    "src/services/kv/**",
    "src/web/**"
  ]
}
