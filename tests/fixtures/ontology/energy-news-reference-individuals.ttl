enews:DataCenterDemand a enews:EnergyTopic,
        skos:Concept ;
    rdfs:label "data center demand"@en ;
    skos:altLabel "AI energy demand"@en,
        "data center energy"@en ;
    skos:broader enews:AIAndDataCenterDemand ;
    skos:definition "A skos:Concept representing electricity demand from data centers and artificial intelligence workloads"@en ;
    skos:inScheme enews:EnergyTopicScheme .

enews:DirectAirCapture a enews:EnergyTopic,
        skos:Concept ;
    rdfs:label "direct air capture"@en ;
    skos:altLabel "DAC"@en,
        "carbon removal"@en ;
    skos:broader enews:CarbonCapture ;
    skos:definition "A skos:Concept representing technologies that capture carbon dioxide directly from ambient air"@en ;
    skos:inScheme enews:EnergyTopicScheme .

enews:LNGTradeAndInfrastructure a enews:EnergyTopic,
        skos:Concept ;
    rdfs:label "LNG trade and infrastructure"@en ;
    skos:altLabel "LNG terminal"@en,
        "LNG trade"@en,
        "liquefied natural gas trade"@en ;
    skos:broader enews:EnergyTradeAndSupplyChains ;
    skos:definition "A skos:Concept representing the international trade, pricing, and physical infrastructure for liquefied natural gas"@en ;
    skos:inScheme enews:EnergyTopicScheme .

enews:status_Decommissioned a enews:ProjectStatus ;
    rdfs:label "decommissioned"@en ;
    skos:definition "A ProjectStatus indicating the project has been permanently shut down and removed"@en .

enews:status_Mothballed a enews:ProjectStatus ;
    rdfs:label "mothballed"@en ;
    skos:definition "A ProjectStatus indicating the project is temporarily shut down but could restart"@en .

enews:status_Operational a enews:ProjectStatus ;
    rdfs:label "operational"@en ;
    skos:definition "A ProjectStatus indicating the project is completed and generating energy"@en .

enews:status_Planning a enews:ProjectStatus ;
    rdfs:label "planning"@en ;
    skos:definition "A ProjectStatus indicating the project is in early planning and permitting phases"@en .

enews:status_UnderConstruction a enews:ProjectStatus ;
    rdfs:label "under construction"@en ;
    skos:definition "A ProjectStatus indicating the project is actively being built"@en .

enews:status_UnderReview a enews:ProjectStatus ;
    rdfs:label "under review"@en ;
    skos:definition "A ProjectStatus indicating the project is undergoing regulatory or environmental review"@en .

